{
  "name": "moonai",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "deploy": "bun run scripts/deploy.ts",
    "hashes": "bun run scripts/hashes.ts",
    "demo": "bun run scripts/agents-demo.ts",
    "match": "bun run apps/orchestrator/src/index.ts",
    "web": "bun --filter @moonai/web dev",
    "test": "bun test",
    "test:contracts": "cd moonai-contracts && cargo odra test",
    "lint": "biome check .",
    "format": "biome check --write .",
    "contracts:build": "cd moonai-contracts && cargo odra build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1"
  },
  "dependencies": {
    "casper-js-sdk": "5.0.12"
  }
}

# Copy to .env (gitignored) and fill in. NEVER commit real secrets.

# ─── LLM (OpenAI-compatible; point BASE_URL/MODEL at any gateway) ───
OPENAI_API_KEY=
# MOONAI_LLM_BASE_URL=https://api.openai.com/v1
MOONAI_LLM_MODEL=gpt-4o-mini

# ─── Casper Testnet ───
CASPER_CHAIN_NAME=casper-test
CASPER_NODE_RPC=https://node.testnet.cspr.cloud/rpc
CSPR_CLOUD_API_KEY=
# Deployer / orchestrator key (Account 4). Point at a PEM OUTSIDE the repo; never commit it.
CASPER_SECRET_KEY_PATH=

# ─── Deployed contract package hashes (public; read via `bun run hashes`) ───
MOONAI_ARENA_PACKAGE_HASH=hash-d712361292da533be2273254c1c3a343ba008ac1be5e8d863b327a281f4c3e64
MOONAI_TOKEN_PACKAGE_HASH=hash-2de0af130a281c820508dd3a8f55a37703021a56c587bd779ebddd2ef156f16c
